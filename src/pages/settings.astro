---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Ajustes">
	<div class="space-y-8 pb-10">
    <!-- BANNER DE ALARMAS MUDADO AQUÍ -->
    <div id="permission-banner" class="hidden w-full p-6 card-purple card-3d flex-col space-y-4">
      <div class="flex items-center space-x-4">
        <div class="bg-white/40 p-3 rounded-2xl">
          <i data-lucide="bell-ring" class="w-8 h-8 text-[#ce82ff]"></i>
        </div>
        <div class="flex-1 text-left">
          <p class="font-black text-gray-800 text-sm uppercase leading-tight">Estado Alarma</p>
          <p id="alarm-status-text" class="text-[10px] text-gray-600 font-bold uppercase tracking-tight leading-tight">Comprobando permisos...</p>
        </div>
      </div>
      <button id="fix-permissions" class="btn-3d btn-3d-blue py-3 flex-1 text-xs">ACTIVAR AHORA</button>
    </div>

		<div class="p-6 border-2 border-gray-100 rounded-3xl space-y-6">
			<div>
        <h3 class="font-black text-gray-700 uppercase tracking-tight text-sm">Copia de Seguridad</h3>
			  <p class="text-[10px] text-gray-400 font-bold uppercase">Administra tus datos locales.</p>
      </div>
			
      <div class="flex flex-col gap-5">
        <button id="export-btn" class="btn-3d btn-3d-blue">
          <i data-lucide="download" class="w-5 h-5 mr-2"></i>
          EXPORTAR DATOS
        </button>
        
        <button id="import-trigger-btn" class="btn-3d btn-3d-gray">
          <i data-lucide="upload" class="w-5 h-5 mr-2"></i>
          IMPORTAR DATOS
        </button>
        <input type="file" id="import-input" class="hidden" accept=".json" />
      </div>
		</div>

    <div class="p-6 border-2 border-gray-100 rounded-3xl space-y-4 bg-gray-50/30 text-center">
			<p class="text-[10px] text-gray-300 font-black uppercase tracking-widest leading-relaxed">Tocatoma v1.0.0<br/>Desarrollado para Jaime</p>
		</div>
	</div>

	<script>
		import { SqliteDatabase } from '../features/shared/infrastructure/SqliteDatabase';
    import { Filesystem, Directory, Encoding } from '@capacitor/filesystem';
    import { createIcons, Download, Upload, BellRing } from 'lucide';
    import { registerPlugin } from '@capacitor/core';
    import { App } from '@capacitor/app';

    const AlarmPlugin = registerPlugin<any>('AlarmPlugin');

    const initSettings = async () => {
      const exportBtn = document.getElementById('export-btn');
      const importTrigger = document.getElementById('import-trigger-btn');
      const importInput = document.getElementById('import-input') as HTMLInputElement;
      const banner = document.getElementById('permission-banner');
      const fixBtn = document.getElementById('fix-permissions');
      const statusText = document.getElementById('alarm-status-text');

      createIcons({ icons: { Download, Upload, BellRing } });

      const checkPerms = async () => {
        try {
          const perms = await AlarmPlugin.checkPermissions();
          if (perms.exactAlarm) {
            banner?.classList.remove('hidden'); banner?.classList.add('flex');
            statusText!.innerText = "PERMISOS ACTIVADOS CORRECTAMENTE";
            fixBtn!.classList.add('hidden');
          } else {
            banner?.classList.remove('hidden'); banner?.classList.add('flex');
            statusText!.innerText = "LAS ALARMAS ESTÁN DESACTIVADAS";
            fixBtn!.classList.remove('hidden');
          }
        } catch (e) { console.warn(e); }
      };

      if (fixBtn) fixBtn.onclick = () => AlarmPlugin.requestPermissions();
      checkPerms();
      App.addListener('appStateChange', ({ isActive }) => { if (isActive) checkPerms(); });

      if (exportBtn) exportBtn.onclick = async () => {
        try {
          const db = SqliteDatabase.getInstance();
          await db.init();
          const conn = db.getDb();
          const data = {
            medications: (await conn.query("SELECT * FROM medications")).values,
            schedules: (await conn.query("SELECT * FROM schedules")).values,
            logs: (await conn.query("SELECT * FROM intake_logs")).values
          };
          const fileName = `tocatoma_backup_${Date.now()}.json`;
          await Filesystem.writeFile({
            path: fileName,
            data: JSON.stringify(data),
            directory: Directory.Documents,
            encoding: Encoding.UTF8,
          });
          alert(`Backup guardado en Documentos.`);
        } catch (e) { alert('Error exportando'); }
      };

      if (importTrigger) importTrigger.onclick = () => importInput.click();

      importInput?.addEventListener('change', async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = async (event) => {
          try {
            const data = JSON.parse(event.target?.result as string);
            const db = SqliteDatabase.getInstance();
            await db.init();
            const conn = db.getDb();

            // LIMPIEZA TOTAL ANTES DE IMPORTAR
            await conn.execute("DELETE FROM intake_logs; DELETE FROM schedules; DELETE FROM medications;");

            for (const med of (data.medications || [])) {
              await conn.run("INSERT INTO medications (id, name, photoUri, color, daysOfWeek) VALUES (?, ?, ?, ?, ?)", 
                [med.id, med.name, med.photoUri, med.color, med.daysOfWeek]);
            }
            for (const sched of (data.schedules || [])) {
              await conn.run("INSERT INTO schedules (id, medicationId, time, systemRingtoneUri) VALUES (?, ?, ?, ?)", 
                [sched.id, sched.medicationId, sched.time, sched.systemRingtoneUri]);
            }
            for (const log of (data.logs || [])) {
              await conn.run("INSERT INTO intake_logs (id, scheduleId, timestamp, status) VALUES (?, ?, ?, ?)", 
                [log.id, log.scheduleId, log.timestamp, log.status]);
            }
            alert("¡Importación completada!");
            window.location.href = "/index.html";
          } catch (err) { alert("Error: El archivo no es un backup válido."); }
        };
        reader.readAsText(file);
      });
    };

    document.addEventListener('DOMContentLoaded', initSettings);
    initSettings();
	</script>
</MainLayout>
